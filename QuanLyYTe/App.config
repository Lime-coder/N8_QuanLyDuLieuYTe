<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<!-- Schema/Owner đang chứa các Stored Procedure quản trị (GET_ALL_USERS, GET_ALL_ROLES, ...) -->
		<!-- Ví dụ: hospital_dba hoặc SYS. Nếu để trống thì gọi theo schema đang login. -->
		<add key="SecurityAdminSPOwner" value="hospital_dba" />
	</appSettings>
	<connectionStrings>
		<add name="HospitalDB"
			 connectionString="User Id=hospital_dba; Password=123; Data Source=localhost:1521/XEPDB1;"
			 providerName="Oracle.ManagedDataAccess.Client" />
	</connectionStrings>
</configuration>